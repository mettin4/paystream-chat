# Example environment configuration for PayStream Chat.
# Copy this file to .env.local and replace placeholder values with real ones.
# The .env.example file IS committed; .env.local is NOT.

# -----------------------------------------------------------------------------
# Circle Nanopayments (developer-controlled wallets + x402 batching)
# -----------------------------------------------------------------------------
# All five values are required by lib/circle.ts. Must never be imported from
# client code — these are server-only secrets.

# Sandbox API key from https://console.circle.com/
CIRCLE_API_KEY=TEST_API_KEY:...

# 32-byte entity secret, hex-encoded. Generate once with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then register it with Circle via the SDK's `registerEntitySecretCiphertext`.
# Save the recovery file somewhere durable (not just .env.local).
CIRCLE_ENTITY_SECRET=deadbeef...

# The operator wallet that funds all user prompts. Get the id + address from
# Circle Console (Wallets → pick one of your three → copy id and address).
# Must be on ARC-TESTNET and have USDC deposited into the GatewayWallet
# contract (see scripts/deposit-operator.ts).
CIRCLE_OPERATOR_WALLET_ID=wallet-uuid-here
CIRCLE_OPERATOR_WALLET_ADDRESS=0x...

# The address that receives Nanopayments from the operator. Typically a
# second Circle Console wallet. Do NOT set this to the operator address —
# Gateway rejects self-settlement.
CIRCLE_RECIPIENT_ADDRESS=0x...

# -----------------------------------------------------------------------------
# Arc Testnet
# -----------------------------------------------------------------------------
# Public explorer URL used to build tx-hash links in the UI. NEXT_PUBLIC_
# prefix means this value WILL be bundled into the browser — non-secret only.
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# -----------------------------------------------------------------------------
# Anthropic (used by lib/anthropic.ts for streaming chat responses)
# -----------------------------------------------------------------------------
# Obtain a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
